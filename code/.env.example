# Copier en .env — jamais commité (cf. .gitignore)
POSTGRES_PASSWORD=change-me-strong
JWT_SECRET=change-me-64-random-chars
# DATABASE_URL est composé automatiquement par docker-compose ;
# hors Docker : postgres://wtp:***@localhost:5432/wheretopark
# CORS_ORIGIN=https://www.wheretopark.app
# Auto-hébergement (docker-compose.selfhost.yml) :
# OSRM_URL=http://localhost:5001        # itinéraires auto-hébergés (URL vue du NAVIGATEUR)
# TILE_URL=https://tiles.mondomaine.fr/dark/{z}/{x}/{y}.png   # tuiles auto-hébergées (optionnel)
